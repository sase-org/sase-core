      "success": "LocalDaemonListResponseWire",
      "type": "list"
    },
    {
      "errors": [
        "LocalDaemonErrorWire"
      ],
      "notes": "typed projection read request/response union for ChangeSpecs, agents, notifications, beads, catalogs, snippets, and file history; Phase 5A implements notifications.read and returns typed fallback errors for the remaining surfaces",
      "request": "LocalDaemonReadRequestWire",
      "success": "LocalDaemonReadResponseWire",
      "type": "read"
    },
    {
      "errors": [
        "LocalDaemonErrorWire"
      ],
      "notes": "framed local subscription stream; server writes one or more LocalDaemonEventBatchWire response frames on the same socket until disconnect or shutdown",
      "request": "LocalDaemonEventRequestWire",
      "success": "LocalDaemonEventBatchWire",
      "type": "events"
    },
    {
      "errors": [
        "LocalDaemonErrorWire"
      ],
      "notes": "runs source-store backfill by default; storage_reset_only preserves the explicit projection reset/replay recovery path",
      "request": "LocalDaemonRebuildRequestWire",
      "success": "LocalDaemonRebuildResponseWire",
      "type": "rebuild"
    },
    {
      "errors": [
        "LocalDaemonErrorWire"
      ],
